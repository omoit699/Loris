# Backend Configuration (copy to Loris-main/trusan-electronics-store/backend/.env)
PORT=5000
NODE_ENV=development

# Frontend URL (for CORS)
# Local development: http://localhost:3000
# Production on Vercel: https://your-vercel-project.vercel.app
FRONTEND_URL=http://localhost:3000

# Frontend build configuration
# Set this to your Render backend URL for production builds
VITE_API_BASE_URL=http://localhost:5000
VITE_BASE_PATH=/

# Production secrets (set securely in Render/Vercel dashboards)
# JWT_SECRET=your_jwt_secret
# SENDGRID_API_KEY=your_sendgrid_api_key
# SENDGRID_FROM_EMAIL=noreply@trusan-electronics.com
# TWILIO_ACCOUNT_SID=your_twilio_account_sid
# TWILIO_AUTH_TOKEN=your_twilio_auth_token
# TWILIO_PHONE_NUMBER=your_twilio_phone_number
